# MongoDB Atlas connection string
# Create cluster at https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/chalk?retryWrites=true&w=majority

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs must include: https://YOUR_RAILWAY_URL/api/auth/google/callback
GOOGLE_CLIENT_ID=1234567890-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# Random string — generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string_at_least_64_chars

# The deployed Vercel URL of THIS backend project (no trailing slash)
# e.g. https://chalk-api.vercel.app
BACKEND_URL=https://chalk-api.vercel.app

# The deployed Vercel URL of the frontend project (no trailing slash)
# e.g. https://chalk-app.vercel.app
FRONTEND_URL=https://chalk-app.vercel.app

NODE_ENV=production

# ── Local dev overrides ────────────────────────────────────────────────────────
# BACKEND_URL=http://localhost:3001
# FRONTEND_URL=http://localhost:5173
# NODE_ENV=development
